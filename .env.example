# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
# Used by services (overridden in docker-compose to point at the rabbitmq host)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- Producer ---
PRODUCER_PORT=3000
PRODUCER_API_PREFIX=api
RABBITMQ_PUBLISH_TIMEOUT_MS=5000
RABBITMQ_PUBLISH_RETRIES=5
RABBITMQ_PUBLISH_BACKOFF_MS=500

# --- Consumer ---
CONSUMER_PORT=3001
CONSUMER_PREFETCH=10
CONSUMER_MAX_ATTEMPTS=5
CONSUMER_RETRY_DELAY_MS=5000
IDEMPOTENCY_CACHE_SIZE=10000

# --- Telegram dispatcher ---
TELEGRAM_PORT=3002
TELEGRAM_BOT_TOKEN=replace-with-real-token
# Optional fallback chat id when the event has no recipient
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_TIMEOUT_MS=8000
TELEGRAM_MAX_ATTEMPTS=5
TELEGRAM_RETRY_DELAY_MS=5000
